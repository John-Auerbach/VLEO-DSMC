SPARTA (24 Sep 2025)
Running on 2 MPI task(s)
# =====================================================================================
# in.esasat_Roar_1FOV_1000
#
# Neutral flux entering the aperture, counting ONLY particles whose velocity vector
# lies within a +/- 1 deg field of view (FOV) of the aperture axis (+x / ram direction).
#
# Assumptions (per request):
#   - Spacecraft speed          : 8 km/s   (vstream = 8000 m/s along +x)
#   - Ambient temperature       : 1000 K   (this script; 2000 K in in.esasat_Roar_1FOV_2000)
#   - Number density per species : 1e6 cm^-3 = 1e12 m^-3  (equal for every species)
#   - Neutral species tracked    : H, He, O
#
# Method: free-molecular freestream. Neutrals drift at 8 km/s with a Maxwellian thermal
# spread set by T. In a thin sampling slab we tally, per species, the x-momentum flux of
# particles whose velocity is within 1 deg of +x, giving the FOV-filtered number flux
#     flux_s = fnum * Sum(vx_i) / V_slab   [ #/m^2/s ]
# summed over in-FOV particles of species s in the slab.
#
# Both temperature cases append their results to the SAME file:
#     dumps/esasat/fov_flux_1deg.dat
# Run this (1000 K) script FIRST: it (re)creates the file; the 2000 K script appends.
# =====================================================================================

# SETUP -------------------------------------------------------------------------------
shell           mkdir -p dumps/esasat

units           si
seed            11111
dimension       3

# outflow in +x, periodic in y,z; inject freestream at xlo
boundary        o p p

# domain size (m)
variable        xmin equal -1.0
variable        xmax equal  1.0
variable        ymin equal -0.5
variable        ymax equal  0.5
variable        zmin equal -0.5
variable        zmax equal  0.5

variable        Lx equal ${xmax}-${xmin}
variable        Lx equal 1-${xmin}
variable        Lx equal 1--1
variable        Ly equal ${ymax}-${ymin}
variable        Ly equal 0.5-${ymin}
variable        Ly equal 0.5--0.5
variable        Lz equal ${zmax}-${zmin}
variable        Lz equal 0.5-${zmin}
variable        Lz equal 0.5--0.5

create_box      ${xmin} ${xmax} ${ymin} ${ymax} ${zmin} ${zmax}
create_box      -1 ${xmax} ${ymin} ${ymax} ${zmin} ${zmax}
create_box      -1 1 ${ymin} ${ymax} ${zmin} ${zmax}
create_box      -1 1 -0.5 ${ymax} ${zmin} ${zmax}
create_box      -1 1 -0.5 0.5 ${zmin} ${zmax}
create_box      -1 1 -0.5 0.5 -0.5 ${zmax}
create_box      -1 1 -0.5 0.5 -0.5 0.5
Created orthogonal box = (-1 -0.5 -0.5) to (1 0.5 0.5)

# free-molecular flow -> collisions negligible, so a coarse grid is sufficient
create_grid     20 10 10 block * * *
Created 2000 child grid cells
  CPU time = 0.012315 secs
  create/ghost percent = 6.39413 93.6059
balance_grid    rcb part
Balance grid migrated 0 cells
  CPU time = 0.000776584 secs
  reassign/sort/migrate/ghost percent = 26.9328 0.314454 4.96714 67.7856

# FREESTREAM CONDITIONS ---------------------------------------------------------------
variable        Tamb   equal 1000.0        # ambient temperature (K)
variable        vx     equal 8000.0        # spacecraft speed (m/s), +x ram direction
variable        nrho_s equal 1.0e12        # per-species number density (1e6 cm^-3)
variable        nrho_t equal 3.0*${nrho_s} # total number density (H + He + O)
variable        nrho_t equal 3.0*1000000000000 
variable        fov    equal 1.0           # FOV half-angle (deg)

# SPECIES AND MIXTURE -----------------------------------------------------------------
# Order sets the particle "type" index: 1=O, 2=He, 3=H
species         species/air.species O He H

mixture         atm nrho ${nrho_t} vstream ${vx} 0.0 0.0 temp ${Tamb}
mixture         atm nrho 3000000000000 vstream ${vx} 0.0 0.0 temp ${Tamb}
mixture         atm nrho 3000000000000 vstream 8000 0.0 0.0 temp ${Tamb}
mixture         atm nrho 3000000000000 vstream 8000 0.0 0.0 temp 1000
mixture         atm He frac 0.3333333333   # He number density = 1e12 m^-3
mixture         atm H  frac 0.3333333333   # H  number density = 1e12 m^-3
mixture         atm O                       # O gets remainder  = 1e12 m^-3

# particle weighting: target ~1e6 simulated particles in the domain
variable        Ns_target equal 5.0e4
variable        Vol       equal ${Lx}*${Ly}*${Lz}
variable        Vol       equal 2*${Ly}*${Lz}
variable        Vol       equal 2*1*${Lz}
variable        Vol       equal 2*1*1
variable        fnum      equal ${nrho_t}*${Vol}/${Ns_target}
variable        fnum      equal 3000000000000*${Vol}/${Ns_target}
variable        fnum      equal 3000000000000*2/${Ns_target}
variable        fnum      equal 3000000000000*2/50000
global          fnum ${fnum}
global          fnum 120000000

# initial fill + continuous freestream injection at xlo
create_particles atm n 0
Created 50000 particles
  CPU time = 0.00592996 secs
fix             in emit/face atm xlo

# balance load periodically
fix             lb balance 500 1.1 rcb part

# FOV FLUX DIAGNOSTIC -----------------------------------------------------------------
# thin sampling slab centered at x=0, spanning the full y,z cross-section
variable        xslab  equal 0.0
variable        dxslab equal 0.02                 # slab thickness (m)
variable        half   equal ${dxslab}/2.0
variable        half   equal 0.02/2.0
variable        Vslab  equal ${Ly}*${Lz}*${dxslab}
variable        Vslab  equal 1*${Lz}*${dxslab}
variable        Vslab  equal 1*1*${dxslab}
variable        Vslab  equal 1*1*0.02

# per-particle masks
variable        inslab particle (x>${xslab}-${half})*(x<${xslab}+${half})
variable        inslab particle (x>0-${half})*(x<${xslab}+${half})
variable        inslab particle (x>0-0.01)*(x<${xslab}+${half})
variable        inslab particle (x>0-0.01)*(x<0+${half})
variable        inslab particle (x>0-0.01)*(x<0+0.01)
variable        incone particle (vx>0)*((atan2(sqrt(vy*vy+vz*vz),vx)*180.0/PI)<=${fov})
variable        incone particle (vx>0)*((atan2(sqrt(vy*vy+vz*vz),vx)*180.0/PI)<=1)

# per-species x-velocity contribution of in-slab, in-FOV particles (type: 1=O,2=He,3=H)
variable        wO  particle vx*v_inslab*v_incone*(type==1)
variable        wHe particle vx*v_inslab*v_incone*(type==2)
variable        wH  particle vx*v_inslab*v_incone*(type==3)

compute         sumO  reduce sum v_wO
compute         sumHe reduce sum v_wHe
compute         sumH  reduce sum v_wH

# EQUILIBRATE (fill the domain to steady state) ---------------------------------------
timestep        5.0e-7
stats           500
stats_style     step cpu np c_sumH c_sumHe c_sumO
run             300
Memory usage per proc in Mbytes:
  particles (ave,min,max) = 3.125 3.125 3.125
  grid      (ave,min,max) = 1.51379 1.51379 1.51379
  surf      (ave,min,max) = 0 0 0
