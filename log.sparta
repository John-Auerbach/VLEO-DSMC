# CONVERT TO NUMBER FLUX (#/m^2/s) and WRITE RESULTS ----------------------------------
variable        fluxH  equal ${fnum}*f_favg[1]/${Vslab}
variable        fluxH  equal 120000000*f_favg[1]/${Vslab}
variable        fluxH  equal 120000000*f_favg[1]/0.02
variable        fluxHe equal ${fnum}*f_favg[2]/${Vslab}
variable        fluxHe equal 120000000*f_favg[2]/${Vslab}
variable        fluxHe equal 120000000*f_favg[2]/0.02
variable        fluxO  equal ${fnum}*f_favg[3]/${Vslab}
variable        fluxO  equal 120000000*f_favg[3]/${Vslab}
variable        fluxO  equal 120000000*f_favg[3]/0.02

# this script creates the shared output file (overwrite), then appends its data row
print           "# Neutral flux entering aperture within +/-${fov} deg FOV (units: #/m^2/s)" file dumps/esasat/fov_flux_1deg.dat
# Neutral flux entering aperture within +/-1 deg FOV (units: #/m^2/s)
print           "# vstream=${vx} m/s, per-species nrho=${nrho_s} m^-3" append dumps/esasat/fov_flux_1deg.dat
# vstream=8000 m/s, per-species nrho=1000000000000 m^-3
print           "# T[K]        H                He               O" append dumps/esasat/fov_flux_1deg.dat
# T[K]        H                He               O
print           "  ${Tamb}   ${fluxH}   ${fluxHe}   ${fluxO}" append dumps/esasat/fov_flux_1deg.dat
  1000   0   8040159725466.7   17423457067971.3

print           "FOV flux (T=${Tamb} K):  H=${fluxH}  He=${fluxHe}  O=${fluxO}  #/m^2/s"
FOV flux (T=1000 K):  H=0  He=8040159725466.7  O=17423457067971.3  #/m^2/s
