surf_collide    probe_t transparent
surf_modify     probe collide probe_t

# SPECIES AND MIXTURE -------------------------------------------------------------------------

# set mixture properties from NRLMSIS data
mixture     	atm nrho ${nrho} vstream ${vx} 0.0 0.0 temp ${T}
mixture     	atm nrho 574610200000000 vstream ${vx} 0.0 0.0 temp ${T}
mixture     	atm nrho 574610200000000 vstream 7725.8 0.0 0.0 temp ${T}
mixture     	atm nrho 574610200000000 vstream 7725.8 0.0 0.0 temp 978.3039

# AMBIPOLAR IONS ------------------------------------------------------------------------------
# Track ions with bound electrons as single ambipolar particles (e is the bound
# electron of each ion). Must be defined before create_particles / emit so that
# created/injected ions carry their electron. Species defined in data/atm.sparta.
fix             ambi ambipolar e O+ N+ O2+ N2+ NO+

# particle weighting: set target of 2e5 sim particles, calculate weighting factor
variable        Ns_target equal 1000000000.0
variable        Vol       equal ${Lx}*${Ly}*${Lz}
variable        Vol       equal 1*${Ly}*${Lz}
variable        Vol       equal 1*1*${Lz}
variable        Vol       equal 1*1*1
variable        fnum      equal ${nrho}*${Vol}/${Ns_target}
variable        fnum      equal 574610200000000*${Vol}/${Ns_target}
variable        fnum      equal 574610200000000*1/${Ns_target}
variable        fnum      equal 574610200000000*1/1000000000
global          fnum ${fnum} # global bc will be queried by each new particle
global          fnum 574610.2 

variable	    parts_per equal ${nrho}/${Ns_target}
variable	    parts_per equal 574610200000000/${Ns_target}
variable	    parts_per equal 574610200000000/1000000000
print "particles per particle = ${parts_per}"
particles per particle = 574610.2

# global useful for stat query later
global          nrho ${nrho}
global          nrho 574610200000000

# create an initial fill (n 0 -> auto compute # of particles from fnum and nrho)
create_particles	atm n 0
Created 652088887 particles
  CPU time = 7.24993 secs

# continuous inflow; inject gas from xlo every step (fix -> run each time step, ID: "in")
fix		        in emit/face atm xlo

# SURFACE COLLISIONS --------------------------------------------------------------------------

                # compute ID, type, surf group, mixture, property (energy flux on surface)
compute         compute_qwall surf ampt atm ke # ke = kinetic + internal energy. W/m^2 *multi-column array for all surface groups

                # running‑average every step so flux is never exactly zero (exponential decay)
fix             flux ave/surf ampt 1 1 1 c_compute_qwall[1] ave running  # running mean, updates each step
fix             fix_Tsurf surf/temp ampt 1 f_flux 300.0 1 Tsurf  # Stefan-Boltzmann

# define collision models (both diffuse, using local facet temp + full accommodation)
surf_collide 	diffuse_xnorm  diffuse s_Tsurf 1   # diffuse model for front/back faces
surf_collide    diffuse_yznorm diffuse s_Tsurf 1   # diffuse model for side walls
# ambipolar ions recombine to their parent neutral on contact with the surface
surf_react      recomb prob surf/esasat.react
# apply to respective surface groups (collide model + ion surface recombination)
surf_modify 	ampt_xnorm  collide diffuse_xnorm  react recomb   # attach model to front/back facets
surf_modify 	ampt_yznorm collide diffuse_yznorm react recomb   # attach model to side-wall facets

# DIAGNOSTICS ---------------------------------------------------------------------------------

                # per-grid properties: nrho, massrho, pxrho (for flow calcs)
compute         prop_grid grid all atm nrho massrho pxrho
                # per-grid temperature
compute         prop_grid_temp grid all atm temp
                # per-grid pressure (thermal/grid supports press property)
compute         prop_grid_press thermal/grid all atm press
                # per-grid velocity components (for streamlines)
compute         prop_grid_flow grid all atm u v w
                # single grid dump with all properties
#dump            dump_grid grid all ${diag_freq} dumps/esasat/grid.*.dat id xlo ylo zlo xc yc zc                     c_prop_grid[*] c_prop_grid_temp[*] c_prop_grid_press[*] c_prop_grid_flow[*]

                # ID, data type, mixture, every _ steps, filename, columns (particle data)
                # p_ionambi = ambipolar flag (1 = ion carrying a bound electron)
#dump            dump_part particle atm ${diag_freq} dumps/esasat/part.*.dat id type x y z vx vy vz p_ionambi

		        # ID, data type, region, every _ steps, filename, columns (facet id, triangle vertices, surface temperature)
#dump    	    dump_surf surf ampt ${diag_freq} dumps/esasat/surf.*.dat id v1x v1y v1z v2x v2y v2z v3x v3y v3z f_flux[*] s_Tsurf

# Measure simulated flow properties for domain ---------------------

compute         vol_grid  property/grid all vol

# Use grid-style variables to multiply density by volume for each cell
variable        nrho_vol grid c_prop_grid[1]*c_vol_grid
variable        rho_vol  grid c_prop_grid[2]*c_vol_grid
variable        px_vol   grid c_prop_grid[3]*c_vol_grid

compute         sum_vol      reduce sum c_vol_grid
compute         sum_nrho_vol reduce sum v_nrho_vol
compute         sum_rho_vol  reduce sum v_rho_vol
compute         sum_px_vol   reduce sum v_px_vol

variable        nrho_avg equal c_sum_nrho_vol/c_sum_vol
variable        rho_avg  equal c_sum_rho_vol/c_sum_vol
variable        ux_avg   equal c_sum_px_vol/c_sum_rho_vol

fix             boxprops ave/time 1 1 100 v_ux_avg v_rho_avg v_nrho_avg ave running file dumps/esasat/box_props.dat

# DRAG CALC (short for caclulator) ------------------------
# sum of surface forces (direct):
                # compute per-surface-element force components (fx,fy,fz) for all ampt surfaces
compute         surfF surf ampt atm fx fy fz
                # time-average per-surf forces (running mean)
fix             surfavg ave/surf ampt 1 1 1 c_surfF[*] ave running
                # reduce (sum) per-surf averaged fx -> global total drag
compute         drag reduce sum f_surfavg[1]

# compute forces for x-normal surfaces (ram drag)
compute         surfF_xnorm surf ampt_xnorm atm fx fy fz
fix             surfavg_xnorm ave/surf ampt_xnorm 1 1 1 c_surfF_xnorm[*] ave running
compute         drag_xnorm reduce sum f_surfavg_xnorm[1]

# compute forces for y/z-normal surfaces (skin friction)
compute         surfF_walls surf ampt_yznorm atm fx fy fz
fix             surfavg_walls ave/surf ampt_yznorm 1 1 1 c_surfF_walls[*] ave running
compute         drag_walls reduce sum f_surfavg_walls[1]

# write drag components (timestep, total_drag, ram_drag, skin_friction) to file
fix             dragout ave/time 1 1 100 c_drag c_drag_xnorm c_drag_walls file dumps/esasat/direct_drag.dat mode scalar

# ----------------------------------------------------------

# cell-averaged (streaming+thermal) temperature
compute         Tbox temp # define a compute Tbox that calculates domain everaged temp
# count ambipolar ions (and electrons, which should stay ~0 since e is always bound)
compute         ions count O+ N+ O2+ N2+ NO+ e

# FLUX CHECK to ensure measured incident flux should be similar to nrho*vstream ----------------------------------------

# split tally into neutral vs ion contributions using a dedicated mixture w/ 2 species groups
# compute surf outputs one column per group, col[1]=neutrals, col[2]=ions
# atm mixture left untouched so drag/grid computes keep single-column layout
# probemix is copied from atm so it inherits nrho/vstream/temp

mixture         atm copy probemix
mixture         probemix N2 O2 O He Ar N group neutrals
mixture         probemix O+ O2+ NO+ N+ N2+ group ions
compute         probe_flux surf probe probemix nflux_incident


fix             probe_avg ave/surf probe 1 1 1 c_probe_flux[*] ave running
compute         probe_neut reduce ave f_probe_avg[1] subset probe   # neutral flux
compute         probe_ion  reduce ave f_probe_avg[2] subset probe   # ion flux
variable        probe_expect equal ${nrho}*${vx}
variable        probe_expect equal 574610200000000*${vx}
variable        probe_expect equal 574610200000000*7725.8
print           "flux check: expected nrho*vstream = ${probe_expect} #/m^2/s"
flux check: expected nrho*vstream = 4.43932348316e+18 #/m^2/s
                # per-group expected flux: ion density = ne (quasineutrality),
                # neutral density = nrho - ne. Both from data/atm.sparta.
variable        probe_expect_ion  equal ${ne}*${vx}
variable        probe_expect_ion  equal 442394500000*${vx}
variable        probe_expect_ion  equal 442394500000*7725.8
variable        probe_expect_neut equal (${nrho}-${ne})*${vx}
variable        probe_expect_neut equal (574610200000000-${ne})*${vx}
variable        probe_expect_neut equal (574610200000000-442394500000)*${vx}
variable        probe_expect_neut equal (574610200000000-442394500000)*7725.8
print           "flux check (ion):     expected ne*vstream       = ${probe_expect_ion} #/m^2/s"
flux check (ion):     expected ne*vstream       = 3.4178514281e+15 #/m^2/s
print           "flux check (neutral): expected (nrho-ne)*vstream = ${probe_expect_neut} #/m^2/s"
flux check (neutral): expected (nrho-ne)*vstream = 4.4359056317319e+18 #/m^2/s

# VELOCITY VECTOR CHECK (fraction of incoming particles within +/-1 deg of +x) --------------------

# per-part off-axis angle (deg) of vel vector from +x axis
variable        offaxis particle atan2(sqrt(vy*vy+vz*vz),vx)*180.0/PI

# thin slab at RAM face (x=-0.4485), spanning full frontal area
# fwd  = forward-moving (vx>0) particles in the slab (the incoming beam)
# cone = subset of fwd within +/-1 deg of +x
variable        fwd  particle (x>-0.4510)*(x<-0.4460)*(vx>0)
variable        cone particle (x>-0.4510)*(x<-0.4460)*(vx>0)*(v_offaxis<=1.0)

compute         n_fwd  reduce sum v_fwd
compute         n_cone reduce sum v_cone
variable        cone_frac equal c_n_cone/c_n_fwd

# running average of the counts + fraction over the whole run
fix             conef ave/time 1 1 ${diag_freq} c_n_cone c_n_fwd v_cone_frac ave running file dumps/esasat/cone_fraction.dat
fix             conef ave/time 1 1 100 c_n_cone c_n_fwd v_cone_frac ave running file dumps/esasat/cone_fraction.dat

# ----------------------------------------------------------

stats           ${diag_freq} # print diagnostics every _ timesteps
stats           100 
                # ... nsreact = surface reactions/step; c_ions[1]=O+, c_ions[6]=e counts
                # c_n_cone/c_n_fwd = live counts; v_cone_frac = fraction within +/-1 deg of +x
stats_style     step cpu np nattempt ncoll nsreact c_Tbox c_drag c_drag_xnorm c_drag_walls c_ions[1] c_ions[6] c_probe_neut c_probe_ion c_n_cone c_n_fwd v_cone_frac

timestep        ${tstep}
timestep        1e-07
                # collide must use a mixture containing ALL species (incl. e, N2+);
                # "all" is the built-in mixture of every species. The flow mixture
                # "atm" (no e) is still what drives create_particles/emit.
collide		    vss all vss/air.vss # variable soft sphere model
collide_modify  ambipolar yes # enable ambipolar ionization/recombination during collisions
run             30000
